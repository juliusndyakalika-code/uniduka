# UniDuka Backend — Environment Variables

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://uniduka:uniduka_dev@localhost:5432/uniduka"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_REFRESH_SECRET="change-me-to-another-long-random-secret"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"

# ── Platform Admin (seeded once on first run) ─────────────────────────────────
PLATFORM_ADMIN_EMAIL="admin@uniduka.com"
PLATFORM_ADMIN_PASSWORD="change-me-strong-password"
PLATFORM_ADMIN_NAME="Platform Administrator"

# ── Email (optional, for invites & notifications) ─────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="UniDuka <no-reply@uniduka.com>"

# ── File Storage (optional) ───────────────────────────────────────────────────
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
